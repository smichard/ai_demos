  "primary_pipeline": "primary",
  "pipelines": [
    {
      "id": "primary",
      "nodes": [
        {
          "id": "fetch-data",
          "type": "execution_node",
          "op": "execute-notebook-node",
          "app_data": {
            "label": "Fetch from S3",
            "component_parameters": {
              "dependencies": [],
              "include_subdirectories": false,
              "outputs": [
                "raw/raw.csv",
                "raw/manifest.json"
              ],
              "env_vars": [
                {
                  "env_var": "AWS_ACCESS_KEY_ID",
                  "value": ""
                },
                {
                  "env_var": "AWS_SECRET_ACCESS_KEY",
                  "value": ""
                },
                {
                  "env_var": "AWS_DEFAULT_REGION",
                  "value": "us-east-1"
                },
                {
                  "env_var": "AWS_S3_ENDPOINT",
                  "value": ""
                },
                {
                  "env_var": "AWS_S3_BUCKET",
                  "value": ""
                },
                {
                  "env_var": "TAXI_RAW_PREFIX",
                  "value": "raw_data/"
                }
              ],
              "kubernetes_pod_annotations": [],
              "kubernetes_pod_labels": [],
              "kubernetes_secrets": [],
              "kubernetes_shared_mem_size": {},
              "kubernetes_tolerations": [],
              "mounted_volumes": [],
              "filename": "1_fetch_from_s3.ipynb",
              "runtime_image": "quay.io/elyra/elyra:3.15.0-py3.10"
            },
            "ui_data": {
              "label": "Fetch from S3",
              "image": "/static/elyra/notebook.svg",
              "x_pos": 100,
              "y_pos": 200,
              "description": "Download NYC taxi data from S3"
            }
          },
          "inputs": [
            {
              "id": "inPort",
              "app_data": {
                "ui_data": {
                  "cardinality": {
                    "min": 0,
                    "max": -1
                  },
                  "label": ""
                }
              }
            }
          ],
          "outputs": [
            {
              "id": "outPort",
              "app_data": {
                "ui_data": {
                  "cardinality": {
                    "min": 0,
                    "max": -1
                  },
                  "label": ""
                }
              }
            }
          ]
        },
        {
          "id": "etl-transform",
          "type": "execution_node",
          "op": "execute-notebook-node",
