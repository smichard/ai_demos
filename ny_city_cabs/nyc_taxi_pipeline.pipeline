                  "env_var": "TAXI_MAX_DURATION_MIN",
                  "value": "180.0"
                },
                {
                  "env_var": "TAXI_MIN_DISTANCE_MI",
                  "value": "0.1"
                },
                {
                  "env_var": "TAXI_MAX_DISTANCE_MI",
                  "value": "50.0"
                },
                {
                  "env_var": "TAXI_MIN_TOTAL_AMOUNT",
                  "value": "2.0"
                },
                {
                  "env_var": "TAXI_MAX_TOTAL_AMOUNT",
                  "value": "500.0"
                },
                {
                  "env_var": "TAXI_MAX_PASSENGERS",
                  "value": "8"
